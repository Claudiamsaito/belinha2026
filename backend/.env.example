# Copie este arquivo para .env e preencha os valores

# Banco de dados (opcional, padrão: missao_saude.db na pasta backend)
DB_PATH=./missao_saude.db

# Segurança JWT (MUDE EM PRODUÇÃO!)
JWT_SECRET=missao-saude-secret-key-MUDE-EM-PRODUCAO
JWT_EXPIRY_HOURS=24

# Admin padrão criado no primeiro start
ADMIN_EMAIL=admin@santacasa.ilhabela.sp.gov.br
ADMIN_SENHA=SantaCasa2024!
ADMIN_NOME=Administrador

# Lista de emails Google permitidos (separados por vírgula)
# Deixe vazio para permitir qualquer email Google
ADMIN_EMAILS_PERMITIDOS=admin@santacasa.ilhabela.sp.gov.br

# Google OAuth (para login com Google)
# Crie em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# URL do frontend (Expo Web)
FRONTEND_URL=http://localhost:8081

# Porta do servidor Flask
PORT=5000
FLASK_DEBUG=true
